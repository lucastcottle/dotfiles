{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg":           "#151515",
    "alt_bg":       "#171717",
    "accent":       "#202020",
    "gray":         "#373737",
    "medium_gray":  "#727272",
    "light_gray":   "#AFAFAF",
    "fg":           "#E1E1E1",
    "blue":         "#BAD7FF",
    "gray_blue":    "#7E97AB",
    "cyan":         "#88afa2",
    "red":          "#b46958",
    "green":        "#90A959",
    "yellow":       "#F4BF75",
    "orange":       "#FFA557",
    "purple":       "#AA749F",
    "sign_add":     "#586935",
    "sign_change":  "#51657B",
    "sign_delete":  "#984936",
    "acc_blue":     "#38404f",
    "acc_green":    "#181B18",
    "acc_red":      "#1B1818"
  },
  "theme": {
    "primary":             { "dark": "blue",        "light": "gray_blue" },
    "secondary":           { "dark": "gray_blue",   "light": "gray_blue" },
    "accent":              { "dark": "cyan",         "light": "cyan" },
    "error":               { "dark": "red",          "light": "red" },
    "warning":             { "dark": "orange",       "light": "orange" },
    "success":             { "dark": "green",        "light": "green" },
    "info":                { "dark": "blue",         "light": "gray_blue" },
    "text":                { "dark": "fg",           "light": "bg" },
    "textMuted":           { "dark": "medium_gray",  "light": "medium_gray" },
    "background":          { "dark": "bg",           "light": "fg" },
    "backgroundPanel":     { "dark": "alt_bg",       "light": "light_gray" },
    "backgroundElement":   { "dark": "accent",       "light": "light_gray" },
    "border":              { "dark": "gray",         "light": "light_gray" },
    "borderActive":        { "dark": "medium_gray",  "light": "medium_gray" },
    "borderSubtle":        { "dark": "accent",       "light": "light_gray" },
    "diffAdded":           { "dark": "green",        "light": "green" },
    "diffRemoved":         { "dark": "red",          "light": "red" },
    "diffContext":         { "dark": "medium_gray",  "light": "medium_gray" },
    "diffHunkHeader":      { "dark": "gray_blue",    "light": "gray_blue" },
    "diffHighlightAdded":  { "dark": "green",        "light": "green" },
    "diffHighlightRemoved":{ "dark": "red",          "light": "red" },
    "diffAddedBg":         { "dark": "acc_green",    "light": "acc_green" },
    "diffRemovedBg":       { "dark": "acc_red",      "light": "acc_red" },
    "diffContextBg":       { "dark": "alt_bg",       "light": "light_gray" },
    "diffLineNumber":      { "dark": "gray",         "light": "light_gray" },
    "diffAddedLineNumberBg":   { "dark": "acc_green", "light": "acc_green" },
    "diffRemovedLineNumberBg": { "dark": "acc_red",   "light": "acc_red" },
    "markdownText":        { "dark": "fg",           "light": "bg" },
    "markdownHeading":     { "dark": "blue",         "light": "gray_blue" },
    "markdownLink":        { "dark": "cyan",         "light": "cyan" },
    "markdownLinkText":    { "dark": "gray_blue",    "light": "gray_blue" },
    "markdownCode":        { "dark": "green",        "light": "green" },
    "markdownBlockQuote":  { "dark": "medium_gray",  "light": "medium_gray" },
    "markdownEmph":        { "dark": "yellow",       "light": "yellow" },
    "markdownStrong":      { "dark": "orange",       "light": "orange" },
    "markdownHorizontalRule": { "dark": "gray",      "light": "light_gray" },
    "markdownListItem":    { "dark": "blue",         "light": "gray_blue" },
    "markdownListEnumeration": { "dark": "cyan",     "light": "cyan" },
    "markdownImage":       { "dark": "cyan",         "light": "cyan" },
    "markdownImageText":   { "dark": "gray_blue",    "light": "gray_blue" },
    "markdownCodeBlock":   { "dark": "fg",           "light": "bg" },
    "syntaxComment":       { "dark": "medium_gray",  "light": "medium_gray" },
    "syntaxKeyword":       { "dark": "purple",       "light": "purple" },
    "syntaxFunction":      { "dark": "blue",         "light": "gray_blue" },
    "syntaxVariable":      { "dark": "fg",           "light": "bg" },
    "syntaxString":        { "dark": "green",        "light": "green" },
    "syntaxNumber":        { "dark": "yellow",       "light": "yellow" },
    "syntaxType":          { "dark": "cyan",         "light": "cyan" },
    "syntaxOperator":      { "dark": "light_gray",   "light": "medium_gray" },
    "syntaxPunctuation":   { "dark": "light_gray",   "light": "medium_gray" }
  }
}
